    },
    {
      "id": "1ff15c77",
      "date": "2026-06-26",
      "title": "Dinner with Ananya",
      "html": "<p>We tried that new Malayali place downtown. Talked for two hours about nothing important and it was perfect.</p>",
      "mood": "great",
      "createdAt": 2026062600000
    },
    {
      "id": "200547c7",
      "date": "2026-06-23",
